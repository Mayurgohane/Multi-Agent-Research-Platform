# Application
APP_NAME=Multi-Agent Academic Research Platform
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Security — leave empty to disable API-key auth (dev only)
API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://marp:marp@localhost:5432/marp

# Redis / ARQ
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# External academic APIs
SEMANTIC_SCHOLAR_API_KEY=
ARXIV_USER_AGENT=MultiAgentResearchPlatform/0.1 (mailto:research@example.com)

# Research defaults
DEFAULT_MAX_PAPERS=20
DEFAULT_MAX_CRITIC_LOOPS=2
HTTP_TIMEOUT_SECONDS=30
